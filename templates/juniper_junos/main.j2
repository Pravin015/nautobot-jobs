## =============================================
## Intended Configuration for {{ obj.name }}
## Location: {{ obj.location.name }}
## Role: {{ obj.role.name }}
## Platform: {{ obj.platform.name }}
## =============================================

system {
    host-name {{ obj.name }};
    domain-name techademy.lab;
    time-zone UTC;
    ## --- AAA ---
    authentication-order [ password ];
    ## --- NTP ---
    ntp {
        server 10.100.0.1 prefer;
        server 10.100.0.2;
    }
    ## --- DNS ---
    name-server {
        10.100.0.10;
        10.100.0.11;
    }
    ## --- Logging ---
    syslog {
        host 10.100.0.20 {
            any info;
        }
        file messages {
            any notice;
            authorization info;
        }
    }
    ## --- Banner ---
    login {
        message "*************************************************************\n* AUTHORIZED ACCESS ONLY                                    *\n* Device: {{ obj.name }} | Location: {{ obj.location.name }}\n*************************************************************";
    }
    ## --- SSH ---
    services {
        ssh {
            protocol-version v2;
            connection-limit 10;
        }
        netconf {
            ssh;
        }
    }
}
## --- SNMP ---
snmp {
    community TechademyRO {
        authorization read-only;
    }
    community TechademyRW {
        authorization read-write;
    }
    location "{{ obj.location.name }}";
    contact "noc@techademy.lab";
}
