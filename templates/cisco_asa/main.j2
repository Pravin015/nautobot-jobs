!
! =============================================
! Intended Configuration for {{ obj.name }}
! Location: {{ obj.location.name }}
! Role: {{ obj.role.name }}
! Platform: {{ obj.platform.name }}
! =============================================
!
hostname {{ obj.name }}
domain-name techademy.lab
!
! --- NTP ---
ntp server 10.100.0.1 prefer
ntp server 10.100.0.2
clock timezone UTC 0
!
! --- DNS ---
dns domain-lookup management
dns server-group DefaultDNS
 name-server 10.100.0.10
 name-server 10.100.0.11
!
! --- SNMP ---
snmp-server community TechademyRO
snmp-server location {{ obj.location.name }}
snmp-server contact noc@techademy.lab
snmp-server enable traps
!
! --- Logging ---
logging enable
logging host management 10.100.0.20
logging trap informational
logging buffer-size 32768
!
! --- Banner ---
banner motd *************************************************************
banner motd * AUTHORIZED ACCESS ONLY
banner motd * Device: {{ obj.name }} | Location: {{ obj.location.name }}
banner motd *************************************************************
!
! --- SSH ---
ssh version 2
ssh timeout 15
!
end
