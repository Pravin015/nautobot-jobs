!
! =============================================
! Intended Configuration for {{ device.name }}
! Location: {{ device.location.name }}
! Role: {{ device.role.name }}
! Platform: {{ device.platform.name }}
! =============================================
!
hostname {{ device.name }}
!
! --- AAA Configuration ---
aaa authentication login default local
aaa authorization exec default local
!
! --- Management ---
service routing protocols model multi-agent
no ip domain-lookup
ip domain-name techademy.lab
!
! --- NTP Configuration ---
ntp server 10.100.0.1 prefer
ntp server 10.100.0.2
clock timezone UTC
!
! --- DNS Configuration ---
ip name-server vrf default 10.100.0.10
ip name-server vrf default 10.100.0.11
!
! --- SNMP Configuration ---
snmp-server community TechademyRO ro
snmp-server community TechademyRW rw
snmp-server location {{ device.location.name }}
snmp-server contact noc@techademy.lab
!
! --- Logging ---
logging buffered 32768
logging host 10.100.0.20
logging trap informational
logging source-interface Loopback0
!
! --- Banner ---
banner motd
*************************************************************
* AUTHORIZED ACCESS ONLY                                    *
* Device: {{ device.name }} | Location: {{ device.location.name }}
*************************************************************
EOF
!
! --- SSH / Management ---
management ssh
  idle-timeout 15
  authentication mode password
!
management api http-commands
  no shutdown
!
end
